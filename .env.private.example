# ManuFoundry private deployment environment.
# Copy to .env on the deployment host and replace every production secret.

# Image source
IMAGE_REGISTRY=ghcr.io
IMAGE_NAMESPACE=yelan-131
IMAGE_TAG=0.3.5-a1b2c3d

# Public endpoints
APP_PUBLIC_URL=http://127.0.0.1
CORS_ORIGINS=["http://127.0.0.1","http://localhost"]
FRONTEND_PORT=80
BACKEND_PORT=8000

# Required production secrets
SECRET_KEY=replace-with-a-random-secret-at-least-32-characters
POSTGRES_USER=manufoundry
POSTGRES_PASSWORD=replace-postgres-password
POSTGRES_DB=manufoundry
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace-neo4j-password

# Infrastructure ports
POSTGRES_PORT=5432
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
REDIS_PORT=6379
REDIS_DB=0

# SMTP for invites and password reset
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@manufoundry.local
SMTP_TLS=true

# AI provider settings
AI_PROVIDER=mock
AI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Optional GHCR login for private images
GHCR_USERNAME=
GHCR_TOKEN=
